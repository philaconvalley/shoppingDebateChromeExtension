{
  "manifest_version": 3,
  "name": "Shopping Debate",
  "version": "1.0.0",
  "description": "Three AI personalities debate your purchase decisions before checkout",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.bundle.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.bundle.js"],
      "css": ["content/debate-modal.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/view.html"
  },
  "options_page": "options/view.html",
  "web_accessible_resources": [
    {
      "resources": [
        "themes/styles/*.css",
        "content/debate-modal.css"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
