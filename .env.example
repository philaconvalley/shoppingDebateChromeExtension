# OpenRouter API Keys (for development)
# Get your keys at: https://openrouter.ai/keys

# Primary API Key (split into two parts for security)
# Part 1: First 8 characters (e.g., "sk-or-v1")
# Part 2: Rest of the key
OPENROUTER_API_KEY_PART1=sk-or-v1
OPENROUTER_API_KEY_PART2=-your-api-key-rest-here

# Secondary API Key (for load balancing and fallback)
# The extension will rotate between keys and fallback if one fails
OPENROUTER_API_KEY2_PART1=sk-or-v1
OPENROUTER_API_KEY2_PART2=-your-second-api-key-rest-here

# Note: In production, users will configure their API key through the extension settings.
# This .env file is only used during development.
